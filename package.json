{
  "name": "kredo-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build:backend": "npm run build -w apps/backend",
    "build:marketing": "npm run build -w apps/marketing-site",
    "build:portal": "npm run build -w apps/app-portal",
    "build:all": "npm run build --workspaces --if-present",
    "dev:backend": "npm run start:dev -w apps/backend",
    "dev:marketing": "npm run dev -w apps/marketing-site",
    "dev:portal": "npm run start -w apps/app-portal",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down"
  },
  "optionalDependencies": {
    "@lightningcss/linux-x64-gnu": "1.32.0",
    "@lightningcss/linux-x64-musl": "1.32.0",
    "@next/swc-linux-x64-gnu": "16.2.10",
    "@next/swc-linux-x64-musl": "16.2.10"
  }
}
